@using LMS.Shared.DTOs.Module
@using LMS.Blazor.Client.Components.Icons

<h2 class="accordion-header">
    <button class="accordion-button module-accordion-button @(IsOpen ? "" : "collapsed") p-3"
            type="button"
            aria-expanded="@IsOpen"
            @onclick="OnToggle">

        <div class="d-flex align-items-center w-100 gap-3">

            <!-- Number -->
            <div class="rounded-circle d-flex align-items-center justify-content-center fw-semibold"
                 style="width: 40px; height: 40px; @CircleStyle">
                @Index
            </div>

            <!-- Text -->
            <div class="flex-grow-1" style="min-width: 0;">
                <div class="d-inline-flex align-items-center gap-2">
                    <span class="fw-semibold text-truncate module-title" style="max-width: 250px;">
                        @Module.Name
                    </span>

                    <span class="badge rounded-pill px-2 py-1 small @BadgeClass">
                        @Status
                    </span>
                </div>

                <div class="text-xs text-muted">
                    @Module.Description
                </div>

                <div class="text-xs text-muted">
                    @Module.StartDate.ToString("dd MMM") - @Module.EndDate.ToString("dd MMM")
                </div>
            </div>

            <!-- Right -->
            <div class="d-flex align-items-center gap-3 ms-auto">

                <AuthorizeView Roles="Teacher">
                    <Authorized>
                        <span class="module-action-icon text-muted"
                              @onclick:stopPropagation="true"
                              @onclick="OnEdit">
                            <EditIcon Size="18" />
                        </span>

                        <span class="module-action-icon text-muted"
                              @onclick:stopPropagation="true"
                              @onclick="OnDelete"
                              data-bs-toggle="modal"
                              data-bs-target="#deleteModuleModal">
                            <TrashIcon Size="18" />
                        </span>

                        <div class="module-header-divider"></div>
                    </Authorized>
                </AuthorizeView>

                <span class="module-chevron">›</span>
            </div>

        </div>
    </button>
</h2>

@code {
    [Parameter] public ModuleDto Module { get; set; } = default!;
    [Parameter] public int Index { get; set; }
    [Parameter] public bool IsOpen { get; set; }

    [Parameter] public string BadgeClass { get; set; } = "";
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public string CircleStyle { get; set; } = "";

    [Parameter] public EventCallback OnToggle { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
}
