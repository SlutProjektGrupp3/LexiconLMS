@using LMS.Blazor.Client.Components.Shared
@using LMS.Shared.DTOs.Module
@inject NavigationManager Navigation

<div class="card p-4 mb-3 accent-card-primary">
    <div class="d-flex justify-content-between align-items-center">
        <span class="badge rounded-pill bg-primary-subtle">
            <span class="text-primary">Current module</span>
        </span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => NavigateToModule()">
            Go to My Course
        </button>
    </div>

    <div class="pb-3">
        <h5 class="fw-bold my-2 pb-3">@CurrentModule?.Name</h5>
        <span class="py-5">@CurrentModule?.Description </span>
    </div>

    @if (CurrentModule != null)
    {
        <ProgressBar Title="Module progress" StartDate="@CurrentModule.StartDate" EndDate="@CurrentModule.EndDate" />
    }
</div>

@code {
    public void NavigateToModule()
    {
        if (CurrentModule != null)
        {
            Navigation.NavigateTo($"/student/mycourse");
        }
    }

    [Parameter] public ModuleDto? CurrentModule { get; set; }
}
