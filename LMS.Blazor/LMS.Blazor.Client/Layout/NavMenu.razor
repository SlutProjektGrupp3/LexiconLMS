@implements IDisposable
@using System.Security.Claims
@using LMS.Shared.DTOs.User
@using LMS.Blazor.Client.Components
@using LMS.Blazor.Client.Components.Icons
@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <BookOpenIcon Size="28" CssClass="text-primary" />
            <span class="h5 mb-0">Lexicon LMS</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView Roles="Teacher" Context="auth">
            <Authorized>
                <div class="d-flex flex-column justify-content-between size">
                    <div >
                        <div class="nav-item">
                            <NavLink class="nav-link" href="teacher/dashboard">
                                <DashboardIcon CssClass="mx-3" /> Dashboard
                            </NavLink>
                        </div>

                        <div class="nav-item">
                            <NavLink class="nav-link" href="teacher/managecourses">
                                <BookOpenIcon CssClass="mx-3" /> Manage Courses
                            </NavLink>
                        </div>

                        <div class="nav-item">
                            <NavLink class="nav-link" href="teacher/manageusers">
                                <ParticipantsIcon CssClass="mx-3" /> Manage Users
                            </NavLink>
                        </div>
                    </div>

                    <div>
                        <!-- Avatar + Name -->
                        <div class="d-flex align-items-center gap-3 px-3 mb-3">

                            <!-- Avatar -->
                            <div class="avatar-circle"
                                 style="background-color:@GetAvatarColor(auth.User)">
                                @GetInitials(auth.User)
                            </div>

                            <div>
                                <h6 class="fw-semibold mb-1 text-light">
                                    @userFirstName @userLastName
                                </h6>

                                <span class="badge rounded-pill @(GetUserRole(auth.User) == "Teacher" ? "bg-info-subtle text-info-emphasis" : "bg-success-subtle text-success")">
                                    @(GetUserRole(auth.User) == "Teacher" ? "Teacher" : "Student")
                                </span>
                            </div>
                        </div>

                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link">
                                <LogOutIcon CssClass="text-danger mx-3" /> 
                                <span class="text-light">Logout</span>
                            </button>
                        </form>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Student" Context="auth">
            <Authorized>
                <div class="d-flex flex-column justify-content-between size">
                   <div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="student/dashboard">
                                <DashboardIcon CssClass="mx-3" /> Dashboard
                            </NavLink>
                        </div>
                        <div class="nav-item">
                            <NavLink class="nav-link" href="student/mycourse">
                                <BookOpenIcon CssClass="mx-3" /> My Course
                            </NavLink>
                        </div>
                   </div>

                   <div>
                    <!-- Avatar + Name -->
                    <div class="d-flex align-items-center gap-3 px-3 mb-3">

                        <!-- Avatar -->
                        <div class="avatar-circle"
                             style="background-color:@GetAvatarColor(auth.User)">
                            @GetInitials(auth.User)
                        </div>

                        <div>
                            <h6 class="fw-semibold mb-1 text-light">
                                @userFirstName @userLastName
                            </h6>

                            <span class="badge rounded-pill @(GetUserRole(auth.User) == "Teacher" ? "bg-info-subtle text-info-emphasis" : "bg-success-subtle text-success")">
                                @(GetUserRole(auth.User) == "Teacher" ? "Teacher" : "Student")
                            </span>
                        </div>
                    </div>

                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <LogOutIcon CssClass="text-danger mx-3" />
                            <span class="text-light">Logout</span>
                        </button>
                    </form>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>
@code {
    private string? currentUrl;
    private string? fullName;
    private string? userFirstName;
    private string? userLastName;
    private string? userRoleName;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private string GetInitials(ClaimsPrincipal user)
    {
        fullName = user.Identity?.Name;
        userFirstName = fullName?.Split(' ').FirstOrDefault() ?? "";
        userLastName = fullName?.Split(' ').Skip(1).FirstOrDefault() ?? "";

        return $"{userFirstName.FirstOrDefault()}{userLastName.FirstOrDefault()}".ToUpper();
    }

    private string GetAvatarColor(ClaimsPrincipal user)
    {
        // deterministic "random" color based on user's full name
        var colors = new[]
        {
            "#6366f1", // indigo
            "#0ea5e9", // sky
            "#10b981", // emerald
            "#f59e0b", // amber
            "#ef4444", // red
            "#8b5cf6", // purple
            "#ec4899"  // pink
        };

        fullName = user.Identity?.Name;
        var hash = fullName.GetHashCode();
        var index = Math.Abs(hash) % colors.Length;

        return colors[index];
    }

    private string GetUserRole(ClaimsPrincipal user)
    {
        return user.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "";
    }
}

