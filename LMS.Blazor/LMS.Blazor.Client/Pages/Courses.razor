@using LMS.Blazor.Client.Components.Shared
@using LMS.Blazor.Client.Components.Courses

@page "/courses"

<h1 class="mb-4">Kurser</h1>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="mb-4">
    <QuickActionButton Text="Skapa ny kurs"
                       Icon="+"
                       OnClick="ToggleCreateForm" />
</div>

@if (showCreateForm)
{
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <CreateCourseForm OnCourseCreated="HandleCourseCreated"
                              OnCancel="HandleCancelCreate" />
        </div>
    </div>
}

@code {
    private bool showCreateForm;
    private string? successMessage;

    private Task ToggleCreateForm()
    {
        successMessage = null;
        showCreateForm = !showCreateForm;
        return Task.CompletedTask;
    }

    private Task HandleCourseCreated()
    {
        showCreateForm = false;
        successMessage = "Kursen har lagts till.";
        return Task.CompletedTask;
    }

    private Task HandleCancelCreate()
    {
        showCreateForm = false;
        return Task.CompletedTask;
    }
}