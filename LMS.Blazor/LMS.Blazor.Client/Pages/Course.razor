@page "/courses/{Id:guid}"
@inject IApiService ApiService
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Activity

@if(isLoading)
{
    <p><em>Loading...</em></p>
}
else if (error != null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @error
    </div>
}
else if (_course != null)
{
    @*Title*@
    <h1>@_course.Name</h1>
    <h2>Moduler</h2>
    foreach (var module in _course.Modules)
    {
        <div>
            <h3>@module.Name</h3>
            <p>@module.Description</p>

            <button @onclick="() => ToggleActivitiesAsync(module.Id)">
                @(_moduleActivities.ContainsKey(module.Id) ? "Hide Activities" : "Show Activities")
            </button>

            <button class="btn btn-success btn-sm ms-2" @onclick="() => ToggleCreateForm(module.Id)">
                @(_showCreateForm.GetValueOrDefault(module.Id) ? "Cancel" : "Add Activity")
            </button>

            @if (_showCreateForm.GetValueOrDefault(module.Id))
            {
                <div class="card mt-3 p-3 bg-light">
                    <h5>Create New Activity</h5>
                    <EditForm Model="_newActivities[module.Id]" OnValidSubmit="() => HandleCreateActivity(module.Id)">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-2">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_newActivities[module.Id].Name" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Type (e.g., Assignment, Lecture)</label>
                            <InputText class="form-control" @bind-Value="_newActivities[module.Id].ActivityTypeName" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Description</label>
                            <InputText class="form-control" @bind-Value="_newActivities[module.Id].Description" />
                        </div>
                        <div class="row mb-2">
                            <div class="col">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="_newActivities[module.Id].StartDate" />
                            </div>
                            <div class="col">
                                <label class="form-label">End Date</label>
                                <InputDate class="form-control" @bind-Value="_newActivities[module.Id].EndDate" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-success mt-2">Save Activity</button>
                    </EditForm>
                </div>
            }

            @if (_loadingModules.Contains(module.Id))
            {
                <p><em>Loading activities...</em></p>
            }
            else if (_moduleActivities.TryGetValue(module.Id, out var activities))
            {
                <div>
                    @if (activities.Any())
                    {
                        @foreach (var activity in activities)
                        {
                            <div>
                                <p><strong>@activity.Name</strong> (@activity.TypeName)</p>
                                <p>@activity.Description</p>
                                <small>@activity.StartDate.ToShortDateString() - @activity.EndDate.ToShortDateString()</small>
                            </div>
                        }
                    }
                    else
                    {
                        <p>No activities found for this module.</p>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter]
    public Guid Id { get; set; }
    private CourseDetailsDto? _course;
    private string? error;
    private bool isLoading;

    private Dictionary<Guid, List<ActivityDto>> _moduleActivities = new();
    private HashSet<Guid> _loadingModules = new();

    private Dictionary<Guid, bool> _showCreateForm = new();
    private Dictionary<Guid, CreateActivityDto> _newActivities = new();

    protected override async Task OnInitializedAsync()
    {
        //This method run in prerender
        await CallApi();
    }

    private async Task CallApi()
    {
        isLoading = true;
        error = null;
        _course = null;
        try
        {
            _course = await ApiService.GetAsync<CourseDetailsDto>($"api/courses/{Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleActivitiesAsync(Guid moduleId)
    {
        if (_moduleActivities.ContainsKey(moduleId))
        {
            _moduleActivities.Remove(moduleId);
            return;
        }

        _loadingModules.Add(moduleId);
        StateHasChanged();

        try
        {
            var activities = await ApiService.GetAsync<List<ActivityDto>>($"api/activities/modules/{moduleId}");
            _moduleActivities[moduleId] = activities ?? new List<ActivityDto>();
        }
        catch (Exception)
        {
            _moduleActivities[moduleId] = new List<ActivityDto>();
        }
        finally
        {
            _loadingModules.Remove(moduleId);
        }
    }

    private void ToggleCreateForm(Guid moduleId)
    {
        var isCurrentlyShown = _showCreateForm.GetValueOrDefault(moduleId);
        _showCreateForm[moduleId] = !isCurrentlyShown;
        if (_showCreateForm[moduleId] && !_newActivities.ContainsKey(moduleId))
        {
            _newActivities[moduleId] = new CreateActivityDto
            {
                ModuleId = moduleId,
                StartDate = DateTime.Now,
                EndDate = DateTime.Now.AddDays(1)
            };
        }
    }

    private async Task HandleCreateActivity(Guid moduleId)
    {
        var dtoToSave = _newActivities[moduleId];
        try
        {
            var createdActivity = await ApiService.PostAsync<CreateActivityDto, ActivityDto>("api/activities", dtoToSave);
            
            if (createdActivity != null)
            {
                if (_moduleActivities.ContainsKey(moduleId))
                {
                    _moduleActivities[moduleId].Add(createdActivity);
                }
                else
                {
                    await ToggleActivitiesAsync(moduleId);
                }

                _showCreateForm[moduleId] = false;
                _newActivities.Remove(moduleId);
            }
        }
        catch (Exception ex)
        {
            error = "Failed to create activity: " + ex.Message;
        }
    }
}