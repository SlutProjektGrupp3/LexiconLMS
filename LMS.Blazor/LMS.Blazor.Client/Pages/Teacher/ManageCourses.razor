@page "/teacher/managecourses"
@using LMS.Shared.DTOs.Course
@using LMS.Blazor.Client.Components.Shared
@using LMS.Blazor.Client.Components.Courses
@inject IApiService ApiService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Teacher")]

<h4 class="fw-bold mb-0">Course Management</h4>

@if (showSuccessMessage)
{
    <div class="alert alert-success">
        Course updated successfully!
    </div>
}
@if (showDeletedMessage)
{
    <div class="alert alert-success">
        Course deleted successfully.
    </div>
}
@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

<div class="d-flex justify-content-end mt-4 mb-3">
    <QuickActionButton Text="Create Course"
                       Icon="+"
                       OnClick="ToggleCreateForm" />
</div>

@if (showCreateForm)
{
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <CreateCourseForm OnCourseCreated="HandleCourseCreated"
                              OnCancel="HandleCancelCreate" />
        </div>
    </div>
}

@if (isLoading)
{
    <p>Loading courses...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <CoursesList Courses="_courses" OnDeleteClicked="ConfirmDelete" />
}

@if (showDeleteConfirm)
{
    <div class="alert alert-warning mt-3">
        <p>Are you sure you want to delete this course?</p>
        <button class="btn btn-danger me-2" @onclick="DeleteCourse">Yes, delete</button>
        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
    </div>
}

@code {
    private List<CourseDetailsDto> _courses = new();
    private bool isLoading = true;
    private string? errorMessage;
    private bool showSuccessMessage;

    private bool showDeleteConfirm;
    private bool showDeletedMessage;
    private Guid selectedCourseId;
    private bool showCreateForm;
    private string? successMessage;

    private Task ToggleCreateForm()
    {
        successMessage = null;
        showCreateForm = !showCreateForm;
        return Task.CompletedTask;
    }

    private async Task HandleCourseCreated()
    {
        showCreateForm = false;
        successMessage = "Course added.";
        await LoadCourses();
    }

    private Task HandleCancelCreate()
    {
        showCreateForm = false;
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

            var query = uri.Query;

            if (query.Contains("updated=true", StringComparison.OrdinalIgnoreCase))
            {
                showSuccessMessage = true;
            }
            if (uri.Query.Contains("deleted=true", StringComparison.OrdinalIgnoreCase))
            {
                showDeletedMessage = true;
            }

            await LoadCourses();           
            
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
     private async Task LoadCourses()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await ApiService.GetAsync<List<CourseDetailsDto>>("api/courses");
            _courses = result ?? new List<CourseDetailsDto>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
    private Task ConfirmDelete(Guid id)
    {
        selectedCourseId = id;
        showDeleteConfirm = true;
        return Task.CompletedTask;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        selectedCourseId = Guid.Empty;
    }

    private async Task DeleteCourse()
    {
        try
        {
            await ApiService.DeleteAsync($"api/courses/{selectedCourseId}");
            Navigation.NavigateTo("/teacher/managecourses?deleted=true", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}