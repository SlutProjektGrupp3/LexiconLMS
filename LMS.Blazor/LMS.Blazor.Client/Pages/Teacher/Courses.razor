@page "/teacher/courses"
@using LMS.Shared.DTOs.CourseDtos
@inject IApiService ApiService
@attribute [Authorize(Roles = "Teacher")]

<h3>Courses</h3>

@if (isLoading)
{
    <p>Laddar kurser...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (_courses is null || _courses.Count == 0)
{
    <p>Inga kurser hittades.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>StartDate</th>
                <th>EndDate</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in _courses)
            {
                <tr>
                    <td>@course.Name</td>
                    <td>@course.Description</td>
                    <td>@course.StartDate.ToShortDateString()</td>
                    <td>@course.EndDate.ToShortDateString()</td>
                    <td>
                        <NavLink class="btn btn-sm btn-outline-primary"
                                 href="@($"/teacher/courses/edit/{course.Id}")">
                            Edit
                        </NavLink>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CourseDto> _courses = new();
    private bool isLoading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();
    }

    private async Task LoadCourses()
    {
        isLoading = true;
        error = null;

        try
        {
            _courses = await ApiService.GetAsync<List<CourseDto>>("api/courses");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}