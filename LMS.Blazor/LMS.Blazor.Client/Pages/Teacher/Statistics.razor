@using LMS.Blazor.Client.Components.Icons

<div class="d-flex justify-content-between align-items-center">
    <div class="card col-3 p-2 mb-4 shadow-sm border border-light position-relative accent-card-primary">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-primary">
                <BookOpenIcon Size="46" CssClass="bg-primary-subtle mx-3 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column py-2">
                <span class="small lh-1">Active Courses</span>
                <span class="fs-3 lh-1">@ActiveCourses</span>
            </div>
        </div>
    </div>

    <div class="card col-3 p-2 mb-4 shadow-sm border border-light position-relative accent-card-success">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-success">
                <ParticipantsIcon Size="46" CssClass="bg-success-subtle mx-3 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column px-2 py-2">
                <span class="small lh-1">Total Students</span>
                <span class="fs-3 lh-1">@TotalStudents</span>
            </div>
        </div>
    </div>

    <div class="card col-3 p-2 mb-4 shadow-sm border border-light position-relative accent-card-warning">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-warning">
                <WarningIcon Size="46" CssClass="bg-warning-subtle mx-3 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column py-2">
                <span class="small lh-1">Assignment to grade</span>
                <span class="fs-3 lh-1">@AssignmentsToGrade</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int ActiveCourses { get; set; }
    [Parameter] public int TotalStudents { get; set; }
    [Parameter] public int AssignmentsToGrade { get; set; }
}
