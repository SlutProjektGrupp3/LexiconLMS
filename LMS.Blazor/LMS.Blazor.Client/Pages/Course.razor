@page "/courses/{Id:guid}"
@inject IApiService ApiService
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Activity
@using LMS.Shared.DTOs.Modules
@using LMS.Shared.DTOs.Module
@using LMS.Shared.DTOs.User
@using LMS.Blazor.Client.Components
@using LMS.Blazor.Client.Components.Icons

<PageTitle>Course Details</PageTitle>


@if (isLoading)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <p><em>Loading...</em></p>
        </div>
    </div>
}
else if (error != null)
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @error
    </div>
}
else if (_course != null)
{
    <div class="card shadow-sm">
        <div class="card-body">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="mb-0">@_course.Name</h4>
                </div>

                <ShowFormButton ShowForm="_showCreateModuleForm"
                                OnClick="ToggleCreateModuleForm"
                                HiddenText="New Module" />
            </div>

            @if(_showCreateModuleForm)
            {
                <CreateModuleForm Model="_moduleToCreate" OnSubmit="HandleCreateModule" />
            }
            
            <button class="btn btn-primary" @onclick="ToggleAddStudent">
                Add student
            </button>



            @if (showAddStudent)
            {
                <div class="mt-3">

                    <input class="form-control mb-2"
                           placeholder="Search student..."
                           value="@searchTerm"
                           @oninput="OnSearchInput" />

                    @if (selectedStudent != null)
                    {
                        <div class="alert alert-light border py-2 px-3 mb-2">
                            Selected student:
                            <strong>@selectedStudent.FirstName @selectedStudent.LastName</strong>
                            <span class="text-muted">(@selectedStudent.Email)</span>
                        </div>
                    }

                    <div class="border rounded p-2 bg-white" style="min-height: 60px;">
                        @if (filteredStudents.Any())
                        {
                            <div class="list-group">
                                @foreach (var student in filteredStudents)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action"
                                            @onclick="() => SelectStudent(student)">
                                        @student.FirstName @student.LastName
                                        <span class="text-muted small">(@student.Email)</span>
                                    </button>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(searchTerm))
                        {
                            <div class="text-muted small">
                                No students match the search.
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small">
                                Start typing to search for a student.
                            </div>
                        }
                    </div>

                    <button class="btn btn-success mt-2"
                            @onclick="AddStudent"
                            disabled="@(selectedStudent is null)">
                        Add to course
                    </button>

                </div>
            }

            @if (_course.Modules == null || !_course.Modules.Any())
            {
                <p class="text-muted">This course has no modules.</p>
            }
            else
            {
                <div class="accordion" id="modulesAccordion">
                    @foreach (var module in _course.Modules)
                    {
                        var collapseId = $"collapse-{module.Id}";
                        var headingId = $"heading-{module.Id}";
                        var accordionIsOpen = _openModules.Contains(module.Id);

                        <div class="accordion-item">

                            <!-- Header -->
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button @(accordionIsOpen ? "" : "collapsed")"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="@accordionIsOpen"
                                        aria-controls="@collapseId"
                                        @onclick="() => ToggleModuleAsync(module.Id)">
                                    <div class="d-flex flex-column text-start">
                                        <span class="fw-semibold">@module.Name</span>
                                        <small class="text-muted">@module.Description</small>
                                    </div>

                                </button>
                            </h2>

                            <!-- Body -->
                            <div id="@collapseId"
                                 class="accordion-collapse collapse @(accordionIsOpen ? "show" : "")"
                                 data-bs-parent="#modulesAccordion">

                                <div class="accordion-body">

                                    @if (_loadingModules.Contains(module.Id))
                                    {
                                        <div class="text-muted small">Loading activities...</div>
                                    }
                                    else if (_moduleActivities.TryGetValue(module.Id, out var activities))
                                    {
                                        <ShowFormButton ShowForm="_showCreateForm.GetValueOrDefault(module.Id)"
                                                        OnClickWithId="ToggleCreateForm"
                                                        Id="module.Id"
                                                        HiddenText="New Activity" />

                                        @if (_showCreateForm.GetValueOrDefault(module.Id))
                                        {
                                            <AddActivityForm ModuleId="module.Id"
                                                             Model="_newActivities[module.Id]"
                                                             OnSubmit="HandleCreateActivity" />
                                        }

                                        @if (activities.Any())
                                        {
                                            <div class="list-group list-group-flush">
                                                @foreach (var activity in activities)
                                                {
                                                    <div class="list-group-item px-0">
    
                                                        <div class="d-flex justify-content-between align-items-start">
                                                            <div class="fw-semibold">
                                                                @activity.Name
                                                                <span class="text-muted fw-normal small">
                                                                    (@activity.TypeName)
                                                                </span>
                                                            </div>

                                                            <button class="btn btn-sm btn-outline-danger"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#deleteActivityModal"
                                                                    @onclick="() => PrepareToDelete(module.Id, activity.Id)">
                                                                Delete
                                                            </button>
                                                        </div>

                                                        <div class="text-muted small">
                                                            @activity.Description
                                                        </div>

                                                        <div class="text-muted small">
                                                            @activity.StartDate.ToShortDateString()
                                                            -
                                                            @activity.EndDate.ToShortDateString()
                                                        </div>

                                                    </div>
                                                }
                                            </div>
                                            <ConfirmModal ModalId="deleteActivityModal"
                                                          Title="Confirm Deletion"
                                                          Message="Are you sure you want to delete this activity?"
                                                          OnConfirm="() => HandleDeleteActivity(_moduleIdToRemember, _activityIdToRemember)" />
                                        }
                                        else
                                        {
                                            <div class="text-muted small">
                                                This module has no activities.
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }

                </div>
            }

        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }
    private CourseDetailsDto? _course;
    private string? error;
    private bool isLoading = true;
    private bool _showCreateModuleForm = false;

    private CreateModuleDto _moduleToCreate { get; set; }

    private Dictionary<Guid, List<ActivityDto>> _moduleActivities = new();
    private HashSet<Guid> _loadingModules = new();
    private HashSet<Guid> _openModules = new();

    private Dictionary<Guid, bool> _showCreateForm = new();
    private Dictionary<Guid, CreateActivityDto> _newActivities = new();
    private Guid _moduleIdToRemember;
    private Guid _activityIdToRemember;

    private bool showAddStudent = false;
    // All students that are available to be added to the course
    private List<AvailableStudentDto> availableStudents = new();
    private string selectedStudentId = string.Empty;
    // Current value in the search input
    private string searchTerm = string.Empty;
    // Filtered list shown as search results
    private List<AvailableStudentDto> filteredStudents = new();
    // The full selected student object (used for display in UI)
    private AvailableStudentDto? selectedStudent;

   

    protected override async Task OnInitializedAsync()
    {

        //This method run in prerender
        await CallApi();
        
    }

    private async Task CallApi()
    {
        isLoading = true;
        error = null;
        _course = null;
        try
        {
            _course = await ApiService.GetAsync<CourseDetailsDto>($"api/courses/{Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ToggleModuleAsync(Guid moduleId)
    {
        if (_openModules.Contains(moduleId))
        {
            _openModules.Remove(moduleId);
            return;
        }

        _openModules.Add(moduleId);

        // Load data if needed
        if (!_moduleActivities.ContainsKey(moduleId))
        {
            _loadingModules.Add(moduleId);

            StateHasChanged();

            try
            {
                var activities = await ApiService.GetAsync<List<ActivityDto>>($"api/activities/modules/{moduleId}");

                _moduleActivities[moduleId] = activities ?? new List<ActivityDto>();
            }
            catch
            {
                _moduleActivities[moduleId] = new List<ActivityDto>();
            }
            finally
            {
                _loadingModules.Remove(moduleId);
            }
        }
    }

    private void ToggleCreateForm(Guid moduleId)
    {
        var isCurrentlyShown = _showCreateForm.GetValueOrDefault(moduleId);
        _showCreateForm[moduleId] = !isCurrentlyShown;
        if (_showCreateForm[moduleId] && !_newActivities.ContainsKey(moduleId))
        {
            _newActivities[moduleId] = new CreateActivityDto
            {
                ModuleId = moduleId,
                StartDate = DateTime.Now,
                EndDate = DateTime.Now.AddDays(1)
            };
        }
    }

    private void ToggleCreateModuleForm()
    {
        _showCreateModuleForm = !_showCreateModuleForm;

        if (_course != null && _showCreateModuleForm)
        {
            _moduleToCreate = new CreateModuleDto
            {
                CourseId = _course.Id,
                Name = string.Empty,
                Description = string.Empty,
                StartDate = DateTime.Now,
                EndDate = DateTime.Now.AddDays(1)
            };
        }
    }

    private async Task HandleCreateModule()
    {
        var dtoToSave = _moduleToCreate;

        try
        {
            var result = await ApiService.PostAsync<CreateModuleDto, CreateModuleResultDto>("api/modules", dtoToSave);

            if (result is { Succeeded: true, CreatedModule: { } createdModule })
            {
                _course!.Modules.Add(createdModule);
                _showCreateModuleForm = false;
            }
        }
        catch (Exception ex)
        {
            error = "Failed to create module: " + ex.Message;
        }
    }

    private async Task HandleCreateActivity(Guid moduleId)
    {
        var dtoToSave = _newActivities[moduleId];
        try
        {
            var createdActivity = await ApiService.PostAsync<CreateActivityDto, ActivityDto>("api/activities", dtoToSave);

            if (createdActivity != null)
            {
                if (_moduleActivities.ContainsKey(moduleId))
                {
                    _moduleActivities[moduleId].Add(createdActivity);
                }

                _showCreateForm[moduleId] = false;
                _newActivities.Remove(moduleId);
            }
        }
        catch (Exception ex)
        {
            error = "Failed to create activity: " + ex.Message;
        }
    }

    private async Task HandleDeleteActivity(Guid moduleId, Guid activityId)
    {
        try
        {
            await ApiService.DeleteAsync($"api/activities/{activityId}");

            if (_moduleActivities.ContainsKey(moduleId))
            {
                var activityToRemove = _moduleActivities[moduleId].FirstOrDefault(a => a.Id == activityId);
                if (activityToRemove != null)
                {
                    _moduleActivities[moduleId].Remove(activityToRemove);
                }
            }
        }
        catch (Exception ex)
        {
            error = "Failed to delete activity: " + ex.Message;
        }
    }
    private void PrepareToDelete(Guid moduleId, Guid activityId)
    {
        _moduleIdToRemember = moduleId;
        _activityIdToRemember = activityId;

    }

    private async Task ToggleAddStudent()
    {
        showAddStudent = !showAddStudent;

        if (showAddStudent)
        {
            // Reset UI state
            selectedStudent = null;
            selectedStudentId = string.Empty;
            searchTerm = string.Empty;

            // fetch fresh data from API when component open
            availableStudents = await ApiService.GetAsync<List<AvailableStudentDto>>(
                $"api/courses/{Id}/available-students"
            ) ?? new();

            // Do not show results until user starts typing
            filteredStudents = new List<AvailableStudentDto>();
        }
    }


    private async Task AddStudent()
    {
        if (string.IsNullOrWhiteSpace(selectedStudentId))
        {
            error = "Välj en elev först.";
            return;
        }

        try
        {
            await ApiService.PostAsync<object>($"api/courses/{Id}/students/{selectedStudentId}", new { });

            showAddStudent = false;
            selectedStudentId = string.Empty;
            selectedStudent = null;
            searchTerm = string.Empty;
            error = null;

            // Refresh available students so the added one disappears from the list
            availableStudents = await ApiService.GetAsync<List<AvailableStudentDto>>(
                $"api/courses/{Id}/available-students"
            ) ?? new();

            filteredStudents = availableStudents;
            await CallApi();
        }
        catch (Exception ex)
        {
            error = "Failed to add student: " + ex.Message;
        }
    }

    private void FilterStudents()
    {
        // If search is empty, do not show any results
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredStudents = new List<AvailableStudentDto>();
            return;
        }

        var term = searchTerm.Trim();

        
        // Filter by first name, last name, full name, or email
        filteredStudents = availableStudents
            .Where(s =>
                s.FirstName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                s.LastName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                $"{s.FirstName} {s.LastName}".Contains(term, StringComparison.OrdinalIgnoreCase) ||
                s.Email.Contains(term, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void SelectStudent(AvailableStudentDto student)
    {
        selectedStudent = student;
        selectedStudentId = student.Id;
        filteredStudents = new List<AvailableStudentDto>();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        // Update search term from input field
        searchTerm = e.Value?.ToString() ?? string.Empty;

        // Trigger filtering as user types
        FilterStudents();
    }
}