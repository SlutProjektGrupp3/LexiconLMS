@page "/teacher/dashboard"
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.CourseDtos
@attribute [Authorize(Roles = "Teacher")]
@inject IApiService ApiService

<PageTitle>Dashboard – Lexicon LMS</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-0">Teacher Dashboard</h4>
        <p class="text-muted small mb-0">@DateTime.Today.ToString("dddd, dd MMMM yyyy")</p>
    </div>    
</div>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    <div class="row">
        <div class="col">
            <div class="card p-3">
                <h5>Active Courses</h5>
                <h2>@Courses.Count</h2>
            </div>
        </div>
    </div>
    <hr />
    <div class="row">
        @foreach (var course in Courses)
        {
            <div class="col-4 mb-3">
                <div class="card shadow-sm p-3">
                    <h5>@course.Name</h5>

                    <button class="btn btn-primary btn-sm"
                            @onclick="() => SelectCourse(course.Id)">
                        Show participants
                    </button>
                </div>
            </div>
        }
    </div>

    @if (SelectedCourse != null)
    {
        <hr />
        <h4>📚 @SelectedCourse.Name</h4>
        <p>@participants.Count participants</p>
        @if (participants.Any())
        {
            <div class="row">
                @foreach (var p in participants)
                {
                    <div class="col-4 mb-2">
                        <div class="card p-2">
                            <strong>@p.FirstName @p.LastName</strong>
                            <div class="text-muted small">@p.Email</div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p>No participants found</p>
        }
    }
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    List<StudentMyCourseDto> Courses = new();
    List<ParticipantDto> participants = new();

    private bool showParticipants = false;

    StudentMyCourseDto? SelectedCourse;

    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();        
    }
    private async Task LoadCourses()
    {        
        try
        {
            var result = await ApiService.GetAsync<List<StudentMyCourseDto>>("api/courses");
            Courses = result ?? new();

        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
    async Task SelectCourse(Guid courseId)
    {
        SelectedCourse = Courses.FirstOrDefault(c => c.Id == courseId);
        await LoadParticipants(courseId);
    }
    private async Task LoadParticipants(Guid courseId)
    {
        participants = await ApiService.GetAsync<List<ParticipantDto>>(
            $"api/courses/{courseId}/participants") ?? new();

    }
   
}
