@page "/teacher/courses"
@using LMS.Shared.DTOs.CourseDtos
@inject IApiService ApiService
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Teacher")]

<h3>Courses</h3>

@if (showSuccessMessage)
{
    <div class="alert alert-success">
        Course updated successfully!
    </div>
}
@if (showDeletedMessage)
{
    <div class="alert alert-success">
        Course deleted successfully.
    </div>
}

@if (isLoading)
{
    <p>Loading courses...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <CoursesList Courses="_courses" OnDeleteClicked="ConfirmDelete" />
}

@if (showDeleteConfirm)
{
    <div class="alert alert-warning mt-3">
        <p>Are you sure you want to delete this course?</p>
        <button class="btn btn-danger me-2" @onclick="DeleteCourse">Yes, delete</button>
        <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
    </div>
}

@code {
    private List<CourseDto> _courses = new();
    private bool isLoading = true;
    private string? errorMessage;
    private bool showSuccessMessage;

    private bool showDeleteConfirm;
    private bool showDeletedMessage;
    private Guid selectedCourseId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

            var query = uri.Query;

            if (query.Contains("updated=true", StringComparison.OrdinalIgnoreCase))
            {
                showSuccessMessage = true;
            }
            if (uri.Query.Contains("deleted=true", StringComparison.OrdinalIgnoreCase))
            {
                showDeletedMessage = true;
            }

            await LoadCourses();           
            
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
     private async Task LoadCourses()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await ApiService.GetAsync<List<CourseDto>>("api/courses");
            _courses = result ?? new List<CourseDto>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
    private Task ConfirmDelete(Guid id)
    {
        selectedCourseId = id;
        showDeleteConfirm = true;
        return Task.CompletedTask;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        selectedCourseId = Guid.Empty;
    }

    private async Task DeleteCourse()
    {
        try
        {
            await ApiService.DeleteAsync($"api/courses/{selectedCourseId}");
            Navigation.NavigateTo("/teacher/courses?deleted=true", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}