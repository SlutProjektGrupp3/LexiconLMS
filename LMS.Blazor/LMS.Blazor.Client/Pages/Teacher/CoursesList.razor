@using LMS.Shared.DTOs.Course

@if (Courses is null || Courses.Count == 0)
{
    <p>No courses found.</p>
}
else
{
    <div class="manage-courses">
        <div class="header">
            <div>
                <h2>Manage Courses</h2>
                <p class="text-muted">Overview of all your courses</p>
            </div>            
        </div>

        <div class="toolbar">
            <input class="form-control" placeholder="Search courses..." @bind="searchTerm" />
        </div>

        <div class="courses-container">
            @if (!FilteredCourses.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-journal-x"></i>
                    <p>No courses found</p>
                </div>
            }
            else
            {
                <div class="course-grid">
                    @foreach (var course in FilteredCourses)
                    {
                        <div class="course-row">

                            <div class="course-icon">
                                <i class="bi bi-book"></i>
                            </div>

                            <div class="course-info">
                                <h5><a href="@($"/courses/{course.Id}")">@course.Name</a></h5>

                                <div class="meta">
                                    <span>📅 @course.StartDate.ToString("yyyy-MM-dd")</span>                                    
                                </div>
                            </div>

                            <div class="course-actions">

                                <NavLink href="@($"/teacher/managecourses/edit/{course.Id}")">
                                    <i class="bi bi-pencil"></i>
                                </NavLink>

                                <button @onclick="() => OnDeleteClicked.InvokeAsync(course.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>

                                <NavLink href="@($"/courses/{course.Id}")">
                                    <i class="bi bi-chevron-right"></i>
                                </NavLink>

                            </div>
                        </div>
                    }

                </div>
            }
        </div>
    </div>   
}

@code {
    [Parameter]
    public List<CourseDto> Courses { get; set; } = new();

    [Parameter]
    public EventCallback<Guid> OnDeleteClicked { get; set; }

    private string searchTerm = "";

    private IEnumerable<CourseDto> FilteredCourses =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? Courses
            : Courses.Where(c =>
                c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
}