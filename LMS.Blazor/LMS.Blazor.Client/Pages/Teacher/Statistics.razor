@using LMS.Blazor.Client.Components.Icons

<div class="d-flex justify-content-between align-items-center">
    <div class="card col-3 mb-4">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-primary">
                <BookOpenIcon Size="56" CssClass="bg-primary-subtle mx-3 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column py-2">
                <span class="fs-6">Active Courses</span>
                <span class="fs-3">@ActiveCourses</span>
            </div>
        </div>
    </div>

    <div class="card col-3 px-3 mb-4">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-success">
                <BookOpenIcon Size="56" CssClass="bg-success-subtle mx-1 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column px-2 py-2">
                <span class="fs-6">Total Students</span>
                <span class="fs-3">@TotalStudents</span>
            </div>
        </div>
    </div>

    <div class="card col-3 mb-4">
        <div class="d-flex justify-content-start align-items-center">
            <div class="text-warning">
                <BookOpenIcon Size="56" CssClass="bg-warning-subtle mx-3 p-2 rounded-2" />
            </div>

            <div class="d-flex flex-column py-2">
                <span class="fs-6">Assignment to grade</span>
                <span class="fs-3">@AssignmentsToGrade</span>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int ActiveCourses { get; set; }
    [Parameter] public int TotalStudents { get; set; }
    [Parameter] public int AssignmentsToGrade { get; set; }
}
