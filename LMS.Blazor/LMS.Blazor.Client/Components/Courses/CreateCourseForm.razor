@using System.ComponentModel.DataAnnotations
@using LMS.Shared.DTOs
@inject IApiService ApiService

<h3 class="mb-4">Lägg till en ny kurs</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<EditForm Model="model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="course-name">Kursnamn</label>
        <InputText id="course-name" placeholder="T.ex. Lexicon LTU" class="form-control" @bind-Value="model.Name" />
        <ValidationMessage For="@(() => model.Name)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="course-description">Beskrivning</label>
        <InputTextArea id="course-description" placeholder="Beskriv kursen (valfritt)" class="form-control" rows="4" @bind-Value="model.Description" />
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label" for="course-startdate">Startdatum</label>
            <InputDate id="course-startdate" @bind-Value="model.StartDate" class="form-control" />
            <ValidationMessage For="@(() => model.StartDate)" class="text-danger" />
          
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label" for="course-enddate">Slutdatum</label>
            <InputDate id="course-enddate" @bind-Value="model.EndDate" class="form-control" />
            <ValidationMessage For="@(() => model.EndDate)" class="text-danger" />
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <button type="button" class="btn btn-outline-secondary" @onclick="HandleCancel" disabled="@isSubmitting">
            Avbryt
        </button>

        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
            @(isSubmitting ? "Sparar..." : "Spara kurs")
        </button>
    </div>
</EditForm>

@code {
    [Parameter]
    public EventCallback OnCourseCreated { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private bool isSubmitting;
    private CreateCourseFormModel model = new();
    private string? errorMessage;

    private async Task HandleCancel()
    {
        errorMessage = null;
        model = new CreateCourseFormModel();

        await OnCancel.InvokeAsync();
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting)
            return;

        errorMessage = null;

        if (model.EndDate <= model.StartDate)
        {
            errorMessage = "Slutdatum måste vara efter startdatum.";
            return;
        }

        var dto = new CreateCourseDto
        {
            Name = model.Name,
            Description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description,
            StartDate = model.StartDate,
            EndDate = model.EndDate
        };

        isSubmitting = true;

        try
        {
            await ApiService.PostAsync("api/courses", dto);

            model = new CreateCourseFormModel();

            await OnCourseCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class CreateCourseFormModel
    {
        [Required(ErrorMessage = "Namn måste anges")]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        [Range(typeof(DateTime), "2000-01-01", "2100-12-31", ErrorMessage = "Startdatum måste anges")]
        public DateTime StartDate { get; set; } = DateTime.Today;

        [Range(typeof(DateTime), "2000-01-01", "2100-12-31", ErrorMessage = "Slutdatum måste anges")]
        public DateTime EndDate { get; set; } = DateTime.Today.AddDays(30);
    }
}