@using LMS.Shared.DTOs.Module
@using LMS.Blazor.Client.Components.Icons

<div class="card p-4 mb-3 accent-card-primary">
    <h6 class="text-dark fw-semibold fs-6">Overview</h6>

    <div class="d-flex justify-content-start align-items-center">
        <span class="text-success"><CircleCheckIcon Size="48" CssClass="bg-success-subtle p-2 rounded-5" /></span>
        <div class="d-flex flex-column align-items-start px-3">
            <span>Completed modules</span>
            <span class="fw-semibold">@CompletedModulesCount of @TotalModulesCount</span>
        </div>
    </div>

    <div class="d-flex justify-content-start align-items-center pt-3">
        <span class="text-primary bg-primary-subtle rounded-5"><BookOpenIcon Size="48" CssClass="p-2" /></span>
        <div class="d-flex flex-column align-items-start px-3">
            <span>Documents</span>
            <span class="fw-semibold">@TotalAvailableDocumentsCount available</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<ModuleDto>? Modules { get; set; }

    public int CompletedModulesCount => Modules?.Count(m => m.EndDate <= DateTime.Now) ?? 0;
    public int TotalModulesCount => Modules?.Count() ?? 0;
    public int TotalAvailableDocumentsCount = 12; // This is a placeholder. We dont have documents upload yet.
}
