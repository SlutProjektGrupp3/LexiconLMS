@using Microsoft.AspNetCore.Components

@if (TotalCount > PageSize)
{
    var totalPages = (int)Math.Ceiling((double)TotalCount / PageSize);
    var window = 2; // show current +/- window
    var startPage = Math.Max(1, CurrentPage - window);
    var endPage = Math.Min(totalPages, CurrentPage + window);

    <nav aria-label="Course pagination" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="Prev">Previous</button>
            </li>

            @if (startPage > 1)
            {
                <li class="page-item">
                    <button class="page-link" @onclick="() => GoTo(1)">1</button>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (int p = startPage; p <= endPage; p++)
            {
                <li class="page-item @(p == CurrentPage ? "active" : "")">
                    <button class="page-link" @onclick="() => GoTo(p)">@p</button>
                </li>
            }

            @if (endPage < totalPages)
            {
                if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item">
                    <button class="page-link" @onclick="() => GoTo(totalPages)">@totalPages</button>
                </li>
            }

            <li class="page-item @(CurrentPage == totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="Next">Next</button>
            </li>
        </ul>
    </nav>
}

@code {
    [Parameter]
    public int CurrentPage { get; set; }

    [Parameter]
    public int PageSize { get; set; }

    [Parameter]
    public int TotalCount { get; set; }

    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    private Task Prev()
    {
        if (CurrentPage > 1)
            return OnPageChanged.InvokeAsync(CurrentPage - 1);
        return Task.CompletedTask;
    }

    private Task Next()
    {
        var totalPages = (int)Math.Ceiling((double)TotalCount / PageSize);
        if (CurrentPage < totalPages)
            return OnPageChanged.InvokeAsync(CurrentPage + 1);
        return Task.CompletedTask;
    }

    private Task GoTo(int p) => OnPageChanged.InvokeAsync(p);
}
