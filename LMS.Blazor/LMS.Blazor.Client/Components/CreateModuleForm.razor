@inject IApiService ApiService
@using LMS.Shared.DTOs.Course
@using LMS.Shared.DTOs.Module

<div class="card mt-3 p-3 bg-light mb-3">
    <h5>Create New Module</h5>

    <EditForm Model="Model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        <div class="mb-2">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="Model.Name" />
            <ValidationMessage For="@(() => Model.Name)" />
        </div>

        <div class="mb-2">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control" @bind-Value="Model.Description" />
            <ValidationMessage For="@(() => Model.Description)" />
        </div>

        <div class="row mb-2">
            <div class="col">
                <label class="form-label">Start Date</label>
                <InputDate class="form-control" @bind-Value="Model.StartDate" />
                <ValidationMessage For="@(() => Model.StartDate)" />
            </div>
            <div class="col">
                <label class="form-label">End Date</label>
                <InputDate class="form-control" @bind-Value="Model.EndDate" />
                <ValidationMessage For="@(() => Model.EndDate)" />
            </div>
        </div>

        <button type="submit" class="btn btn-success mt-2">
            Save Module
        </button>
    </EditForm>
</div>

@code {

    [Parameter]
    public CreateModuleDto Model { get; set; }

    [Parameter]
    public EventCallback OnSubmit { get; set; }

    [Parameter]
    public DateTime CourseStartDate { get; set; }

    [Parameter]
    public DateTime CourseEndDate { get; set; }

    private string? errorMessage;

    private async Task HandleSubmit()
    {
        errorMessage = null;

        errorMessage = null;

        // 1. Start in past
        if (Model.StartDate < DateTime.Today)
        {
            errorMessage = "Start date cannot be in the past.";
            return;
        }

        // 2. End before start
        if (Model.EndDate <= Model.StartDate)
        {
            errorMessage = "End date must be after start date.";
            return;
        }

        // 3. Module must be inside course dates (IMPORTANT FIX)
        if (Model.StartDate < CourseStartDate || Model.EndDate > CourseEndDate)
        {
            errorMessage = "Module must be within course date range.";
            return;
        }

        await OnSubmit.InvokeAsync();
    }
}